# Node — match a real dir AND a worktree symlink (trailing slash misses symlinks)
node_modules
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
.npmrc.local

# Build artifacts
dist/
build/
.svelte-kit/
.next/
.nuxt/
.output/
out/

# TypeScript
*.tsbuildinfo
.tsbuild/

# Test + coverage
coverage/
.nyc_output/

# Cloudflare / wrangler
.wrangler/
wrangler.toml.local

# Env + secrets — NEVER commit
.env
.env.*
!.env.example
*.secret
*.key
!packages/**/test/fixtures/*.key

# Python pipeline
__pycache__/
*.py[cod]
.venv/
.python-version
*.egg-info/
pipeline/cache/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local data (SQLite vault + KCV + OAuth/session store) — runtime, never commit
data/
auth.db
*.db
*.db-shm
*.db-wal
kcv.json

# Claude Code per-developer state
.claude/projects/
.claude/memory/
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
.claude/launch.json

# Local scratch + operator-only debug scripts — never ship in the public repo
scratch/
.tmp/
*.local.md
/_*.mjs

# Tauri (Rust) build artifacts
src-tauri/target/
src-tauri/gen/

# Self-contained .app bundle staging (≈1 GB; rebuilt by scripts/build-app-bundle.sh)
build-staging/
.build-cache/
# Bundled sidecars — fetched by scripts/fetch-sidecars.sh, never committed
src-tauri/binaries/

# public-release hygiene
_*.mjs
/MEMORY.md
.claude/memory/
