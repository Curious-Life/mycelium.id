name = "mya"                               # Worker name (matches workers.dev subdomain)
main = "src/index.ts"
compatibility_date = "2024-11-01"
compatibility_flags = ["nodejs_compat"]
workers_dev = true

# Workers Unbound - allows up to 15 min wall-clock time for I/O operations
[limits]
cpu_ms = 30000

# Workers AI binding
[ai]
binding = "AI"

# R2 bucket for attachments
[[r2_buckets]]
binding = "BUCKET"
bucket_name = "mya-attachments"

# KV namespace for deduplication and caching
[[kv_namespaces]]
binding = "KV"
id = "<YOUR_KV_NAMESPACE_ID>"

# Queue for async Telegram message processing
[[queues.producers]]
binding = "TELEGRAM_QUEUE"
queue = "mya-telegram-messages"

[[queues.consumers]]
queue = "mya-telegram-messages"
max_batch_size = 1
max_batch_timeout = 0
max_retries = 2
dead_letter_queue = "mya-telegram-dlq"

# D1 database
[[d1_databases]]
binding = "DB"
database_name = "mycelium-db"
database_id = "<YOUR_D1_DATABASE_ID>"

# Tenant D1 databases (add per customer)
# [[d1_databases]]
# binding = "DB_TENANT_<user_id>"
# database_name = "mycelium-tenant-<handle>"
# database_id = "<TENANT_D1_ID>"

# Vectorize indexes (semantic search + clustering)
[[vectorize]]
binding = "VECTORS_1024"
index_name = "mycelium-search"

[[vectorize]]
binding = "VECTORS_256"
index_name = "mycelium-cluster"

# Environment variables (secrets set via wrangler secret put)
[vars]
ENVIRONMENT = "production"
OWNER_NAME = "<YOUR_NAME>"

# Dev environment
[env.dev]
name = "mycelium-dev"
[env.dev.vars]
ENVIRONMENT = "development"
