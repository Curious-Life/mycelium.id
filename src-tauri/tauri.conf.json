{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mycelium",
  "version": "0.1.0",
  "identifier": "id.mycelium.app",
  "build": {
    "frontendDist": "../portal",
    "beforeBuildCommand": "bash scripts/build-app-bundle.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "Your private cognitive vault",
    "resources": {
      "../build-staging/": "app"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
