{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mycelium",
  "version": "0.1.3",
  "identifier": "id.mycelium.app",
  "build": {
    "frontendDist": "../portal-app/build",
    "beforeDevCommand": "node scripts/ensure-portal-built.mjs",
    "beforeBuildCommand": "bash scripts/build-app-bundle.sh"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/frpc", "binaries/caddy"],
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "Your private cognitive vault",
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    },
    "resources": {
      "../build-staging/": "app",
      "icons/Assets.car": "."
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
