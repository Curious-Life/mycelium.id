<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the notarized Mycelium.app.
  Wire it in src-tauri/tauri.conf.json:  "bundle": { "macOS": { "entitlements": "entitlements.plist" } }
  (left for the operator to add — tauri.conf.json is touched by another session.)

  Why each is needed (this app embeds Node/V8 + a relocatable Python and spawns
  them as children with env overrides, and loads native modules + sidecars):
    - allow-jit / allow-unsigned-executable-memory  → V8's JIT in the bundled Node
    - allow-dyld-environment-variables              → main.rs sets PATH/HF_HOME/etc. on children
    - disable-library-validation                    → load bundled node/python, the native
      better_sqlite3.node, and the caddy/frpc sidecars (not all team-signed)
  See docs/MAC-APP-RELEASE-RUNBOOK-2026-06-05.md §A.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
