{
  "name": "@mycelium/agent-framework",
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-agent orchestration framework — persistent agents with Claude, Discord, and Cloudflare D1",
  "main": "agent-server.js",
  "scripts": {
    "start": "node agent-server.js",
    "start:orchestrator": "node orchestrator.js",
    "dev": "node --watch agent-server.js",
    "pm2": "pm2 start ecosystem.config.cjs",
    "add-agent": "./scripts/add-agent.sh",
    "test": "node --test 'tests/**/*.test.js'",
    "sbom": "npx @cyclonedx/cyclonedx-npm --output-file sbom.json",
    "audit:check": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sentry/node": "^10.38.0",
    "@simplewebauthn/server": "^13.2.2",
    "@stablelib/blake2s": "^2.0.1",
    "@stablelib/bytes": "^2.0.1",
    "@stablelib/chacha20poly1305": "^2.0.1",
    "@stablelib/hash": "^2.0.0",
    "@stablelib/hkdf": "^2.0.1",
    "@stablelib/hmac": "^2.0.1",
    "@stablelib/x25519": "^2.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "busboy": "^1.6.0",
    "cors": "^2.8.6",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "grammy": "^1.39.2",
    "http-proxy-middleware": "^3.0.5",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "sodium-native": "^5.1.0",
    "unpdf": "^1.4.0",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/mycelium.git"
  },
  "license": "MIT"
}
