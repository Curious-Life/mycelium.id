{
  "name": "mycelium",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mycelium V1 \u2014 self-hosted single-user MCP cognitive vault.",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "init-db": "node scripts/init-db.mjs",
    "verify:foundation": "node scripts/verify-foundation.mjs",
    "verify:mcp": "node scripts/verify-mcp.mjs",
    "verify:mindfiles": "node scripts/verify-mindfiles.mjs",
    "verify:metrics": "node scripts/verify-metrics.mjs",
    "verify:rest": "node scripts/verify-rest.mjs",
    "verify:search": "node scripts/verify-search.mjs",
    "verify:topology": "node scripts/verify-topology.mjs",
    "verify": "npm run verify:foundation && npm run verify:mcp && npm run verify:mindfiles && npm run verify:metrics && npm run verify:rest && npm run verify:search && npm run verify:topology",
    "start": "node src/index.js",
    "rest": "node src/server-rest.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "express": "^4.21.2"
  }
}
