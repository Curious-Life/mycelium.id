# Copy to /etc/mycelium/control-plane.env  →  chmod 600, chown mycelium:mycelium.
# Holds the ONE secret on this box (MYC_DNS_TOKEN). NEVER commit a filled copy and
# NEVER put it in cloud-init (the provider stores cloud-config in plaintext).

PORT=8790
# Loopback-only: the frps plugin + Caddy edge reach it locally; the internet never does.
MYC_BIND_HOST=127.0.0.1

# Your domain is the handle zone → handles become <handle>.yourdomain.com.
MYC_ZONE=yourdomain.com

# This box's public IPv4 — the A record each handle points at (frps :443).
MYC_RELAY_IP=203.0.113.10
# What the Mac's frpc dials (this box, control port 7000).
MYC_RELAY_ADDR=203.0.113.10:7000

# acme-dns split: clients (the Mac's Caddy) push the DNS-01 TXT to the PUBLIC
# /update; the control-plane registers via the PRIVATE loopback API (so /register
# is never exposed to the internet — the Caddy edge only proxies /update).
MYC_ACME_DNS=https://acme.yourdomain.com:8443
MYC_ACME_DNS_REGISTER=http://127.0.0.1:8081

# Apex DNS automation. deSEC (free, DNSSEC) or cloudflare (DNS-only, proxied:false).
# Use a token SCOPED to this one zone with DNS-edit rights only.
MYC_DNS_PROVIDER=desec
MYC_DNS_TOKEN=
# MYC_CF_ZONE_ID=                      # only when MYC_DNS_PROVIDER=cloudflare

MYC_REGISTRY_DB=/var/lib/mycelium/registry.db
# Self-throttle new handles under the CA's per-domain weekly cap.
MYC_MAX_NEW_HANDLES_PER_DAY=40
